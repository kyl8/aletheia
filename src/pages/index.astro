---
// AI VOC ME PERGUNTA PQ VC NAO USOU i18n routing do astro igual no portfolio?
// pq ia dar muito trabalho pra um ganho besta e pra mim ia ser overengineering

import '../styles/global.css';
import Main from '../components/cv/main.tsx';
import { labels } from '../utils/i18n';
---
<html lang="pt-BR" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title id="doc-title">{labels.appName}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Codystar:wght@300;400&family=DotGothic16&family=Press+Start+2P&family=Raleway+Dots&family=Silkscreen:wght@400;700&family=VT323&display=swap" rel="stylesheet">
    
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) return localStorage.getItem('theme');
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
      document.documentElement.classList[theme === 'dark' ? 'add' : 'remove']('dark');
    </script>
    
    <style is:global>
      .font-press-start { font-family: 'Press Start 2P', cursive; }
      .font-silkscreen { font-family: 'Silkscreen', cursive; }
      .font-vt323 { font-family: 'VT323', monospace; }
      .font-dotgothic { font-family: 'DotGothic16', sans-serif; }
      .font-codystar { font-family: 'Codystar', cursive; font-weight: bold; }
      .font-raleway-dots { font-family: 'Raleway Dots', cursive; }

      body {
        font-family: 'VT323', monospace;
        font-size: 1.35rem; 
      }
      input, textarea, select, button {
        font-family: inherit;
      }

      .pixel-box {
        border: 4px solid #18181b;
        box-shadow: 6px 6px 0px 0px #18181b;
        transition: transform 0.1s ease, box-shadow 0.1s ease;
      }
      .dark .pixel-box {
        border: 4px solid #e4e4e7;
        box-shadow: 6px 6px 0px 0px #e4e4e7;
      }
      .pixel-box:active {
        transform: translate(6px, 6px);
        box-shadow: 0px 0px 0px 0px transparent !important;
      }
      
      .pixel-shadow-text { text-shadow: 4px 4px 0px #4f46e5; }
      .dark .pixel-shadow-text { text-shadow: 4px 4px 0px #1e1b4b; }
    </style>
  </head>

  <body class="bg-[#f4f4f5] text-zinc-900 dark:bg-[#09090b] dark:text-zinc-100 min-h-screen flex flex-col transition-colors duration-500 relative tracking-wide overflow-x-hidden">
    <main class="flex-grow flex flex-col items-center pt-12 pb-24 px-4 sm:px-6">
      <div class="w-full max-w-4xl space-y-12 mx-auto">
        
        <header class="text-center space-y-4 mb-12">
          <h1 id="app-title" class="text-4xl md:text-5xl font-press-start pixel-shadow-text bg-gradient-to-b from-indigo-400 to-indigo-600 bg-clip-text text-transparent uppercase py-4">
            {labels.appName}
          </h1>
          <p id="app-subtitle" class="text-lg md:text-xl font-silkscreen text-zinc-700 dark:text-zinc-300">
            {labels.subtitle}
          </p>
          <div class="flex justify-center gap-3 mt-4">
            <div class="h-4 w-4 bg-indigo-500 animate-bounce border-2 border-zinc-900 dark:border-zinc-200"></div>
            <div class="h-4 w-4 bg-purple-500 animate-bounce [animation-delay:0.2s] border-2 border-zinc-900 dark:border-zinc-200"></div>
            <div class="h-4 w-4 bg-emerald-500 animate-bounce [animation-delay:0.4s] border-2 border-zinc-900 dark:border-zinc-200"></div>
          </div>
        </header>

        <Main client:only="react" />
      </div>
    </main>

    <button id="lang-toggle" class="fixed bottom-6 left-6 px-4 py-4 bg-indigo-500 dark:bg-indigo-600 text-white font-silkscreen text-xs uppercase pixel-box z-50 flex items-center justify-center hover:bg-indigo-400 transition-colors" aria-label="Toggle language">
      <span id="lang-text" class="tracking-widest">PT-BR</span>
    </button>

    <button id="theme-toggle" class="fixed bottom-6 right-6 p-4 bg-emerald-400 dark:bg-emerald-500 text-zinc-900 pixel-box z-50 flex items-center justify-center" aria-label="Toggle theme">
      <svg id="theme-toggle-dark-icon" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
      <svg id="theme-toggle-light-icon" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.364 17.636l-.707.707M6.364 6.364l.707.707m11.314 11.314l.707.707M12 5a7 7 0 000 14 7 7 0 000-14z"></path></svg>
    </button>
    
    <script define:vars={{ labels }}>
      const themeToggleBtn = document.getElementById('theme-toggle');
      const darkIcon = document.getElementById('theme-toggle-dark-icon');
      const lightIcon = document.getElementById('theme-toggle-light-icon');
      
      const updateIcons = () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (darkIcon) darkIcon.classList.toggle('hidden', isDark);
        if (lightIcon) lightIcon.classList.toggle('hidden', !isDark);
      };

      updateIcons();
      if (themeToggleBtn) {
        themeToggleBtn.addEventListener('click', () => {
          document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
          updateIcons();
        });
      }

      // I18N
      const langToggleBtn = document.getElementById('lang-toggle');
      const langText = document.getElementById('lang-text');

      if (langToggleBtn) {
        langToggleBtn.addEventListener('click', () => {
          const currentLang = localStorage.getItem('aletheia_lang') || 'pt';
          const newLang = currentLang === 'pt' ? 'en' : 'pt';
          localStorage.setItem('aletheia_lang', newLang);
          window.dispatchEvent(new Event('aletheia-lang-change')); 
        });
      }

      const applyLang = () => {
        const lang = localStorage.getItem('aletheia_lang') || 'pt';
        
        if (langText) langText.textContent = lang === 'pt' ? 'PT-BR' : 'EN-US';

        const titleEl = document.getElementById('app-title');
        const subtitleEl = document.getElementById('app-subtitle');
        const docTitle = document.getElementById('doc-title');

        if (titleEl && labels.appName && labels.appName[lang]) {
          titleEl.textContent = labels.appName[lang];
        }
        if (subtitleEl && labels.subtitle && labels.subtitle[lang]) {
          subtitleEl.textContent = labels.subtitle[lang];
        }
        if (docTitle && labels.appName && labels.subtitle) {
          docTitle.textContent = `${labels.appName[lang]} | ${labels.subtitle[lang]}`;
        }
        
        document.documentElement.lang = lang === 'pt' ? 'pt-BR' : 'en-US';
      };

      applyLang();
      window.addEventListener('aletheia-lang-change', applyLang);
      window.addEventListener('storage', (e) => {
        if (e.key === 'aletheia_lang') applyLang();
      });
    </script>
  </body>
</html>